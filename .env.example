DB_USER=splittogether
DB_PASSWORD=change_me


# App image tag deployed by docker compose. Set to a commit SHA to roll back.
APP_IMAGE_TAG=latest

JWT_SECRET=change_me_to_a_long_random_base64_string

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your@gmail.com

# MinIO / S3 file storage
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=splittogether
# Public base URL of MinIO as reachable by clients (nginx-proxied in prod).
# Must match the host clients connect to, or presigned URL signatures will fail.
MINIO_PUBLIC_ENDPOINT=https://files.88.216.208.6.nip.io:8443

PUSH_ENABLED=false
